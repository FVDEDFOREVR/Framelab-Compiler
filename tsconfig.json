{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "src/analyzed.ts",
    "src/ast.ts",
    "src/cli.ts",
    "src/compiler.ts",
    "src/diagnostics.ts",
    "src/emitter-react.ts",
    "src/ir.ts",
    "src/ir-builder.ts",
    "src/normalize.ts",
    "src/parser.ts",
    "src/tokenizer.ts",
    "src/test.ts",
    "src/validator.ts"
  ]
}
